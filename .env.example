# Copy this file to .env before running the server.
# .env is gitignored and must never be committed.

# Password the creator must enter to start a game.
# Share this out-of-band with the host player.
GAME_PASSWORD=change_me_before_deploying

# Internal port the Node.js server listens on.
# Must match what Caddy proxies to (default: 3000).
PORT=3000

# Path to the compiled React build, relative to the server working directory.
# Defaults to ../dist (the repo root dist/ folder). Override if needed.
# STATIC_DIR=../dist

# For local development only: set this so the React dev server (Vite on :5173)
# can connect to the game server on a different port.
# Leave unset in production (Caddy serves client and server on the same origin).
# VITE_SERVER_URL=http://localhost:3000

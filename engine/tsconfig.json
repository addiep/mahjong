{
  "compilerOptions": {
    "target":                     "ES2022",
    "module":                     "ESNext",
    "moduleResolution":           "bundler",
    "strict":                     true,
    "noUncheckedIndexedAccess":   true,
    "exactOptionalPropertyTypes": true,
    "outDir":                     "./dist",
    "rootDir":                    "./src",
    "declaration":                true,
    "declarationMap":             true,
    "sourceMap":                  true
  },
  "include":  ["src/**/*"],
  "exclude":  ["node_modules", "dist"]
}
